# 数据库（可选，默认 SQLite）
# DATABASE_URL=sqlite:///./supply_chain.db

# JWT 密钥（生产环境务必修改）
# SECRET_KEY=your-secret-key-change-in-production

# LLM 智能体（可选，不配置则用规则引擎）
# DeepSeek 大模型配置
LLM_PROVIDER="deepseek"          # 大模型提供商改为 deepseek
LLM_BASE_URL="https://api.deepseek.com"  # DeepSeek 官方 API 地址
LLM_MODEL="deepseek-chat"         # DeepSeek 主推的对话模型（也可选择 deepseek-coder 针对代码场景）
LLM_API_KEY="sk-04baa98612a9474aacfd3da92043b27f"  # 替换为你自己的 DeepSeek API Key
